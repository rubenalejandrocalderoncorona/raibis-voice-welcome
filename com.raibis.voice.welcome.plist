<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.raibis.voice.welcome</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Use the venv python; replace PATH_TO_REPO with your absolute clone path -->
        <string>PATH_TO_REPO/venv/bin/python3</string>
        <string>PATH_TO_REPO/bienvenido_jarvis.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>PATH_TO_REPO</string>

    <!-- Start automatically when the user logs in -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Restart the script if it exits unexpectedly -->
    <key>KeepAlive</key>
    <true/>

    <!-- Wait 5 seconds before restarting on crash -->
    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>/tmp/raibis-voice-welcome.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/raibis-voice-welcome.error.log</string>
</dict>
</plist>
